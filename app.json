{
  "expo": {
    "name": "Saku Admin",
    "slug": "saku-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo_saku_cl.png",
    "scheme": "sakuadmin",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/logo_saku_cl.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/logo_saku_cl.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.SAKUAMIN.COM",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo_saku_cl.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-notifications",
      "expo-video"
    ],
    "notification": {
      "icon": "./assets/images/logo_saku_cl.png",
      "color": "#63348C"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f265ac07-beb1-47d5-9f6d-d37926115187"
      }
    },
    "owner": "lusvin502gt"
  }
}
