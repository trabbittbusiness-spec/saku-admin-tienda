{
  "expo": {
    "name": "saku-tienda-web",
    "slug": "saku-tienda-web",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo_saku_cl.png",
    "scheme": "sakutiendaweb",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/logo_saku_cl.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo_saku_cl.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.lusvin502gt.sakutiendaweb"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo_saku_cl.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
