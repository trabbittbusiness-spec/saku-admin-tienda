{
  "expo": {
    "name": "Saku Admin",
    "slug": "saku-admin",
    "version": "7.6.4",
    "orientation": "portrait",
    "icon": "./assets/images/logo_saku_cl.png",
    "scheme": "sakuadmin",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/logo_saku_cl.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.SAKUAMIN.COM",
      "buildNumber": "33",
      "appleTeamId": "4H4BJH5HJX",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Esta aplicación necesita acceso a la cámara para tomar fotos de los productos y perfiles.",
        "NSPhotoLibraryUsageDescription": "Esta aplicación necesita acceso a tu galería para subir imágenes de los productos.",
        "NSMicrophoneUsageDescription": "Esta aplicación necesita acceso al micrófono para grabar videos de los productos.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/logo_saku_cl.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.SAKUAMIN.COM",
      "versionCode": 32,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo_saku_cl.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/saku_notification_silhouette.png",
          "color": "#63348C",
          "sounds": [
            "./assets/audio/admin_push.mp3",
            "./assets/audio/admin_push_android.mp3"
          ]
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Esta aplicación necesita acceso a tu galería para subir imágenes de los productos.",
          "cameraPermission": "Esta aplicación necesita acceso a la cámara para tomar fotos de los productos y perfiles.",
          "microphonePermission": "Esta aplicación necesita acceso al micrófono para grabar videos de los productos."
        }
      ],
      "expo-asset",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "404a5ca4-59bb-4a86-896e-44b2ef57a24a"
      }
    },
    "owner": "lusvin502gt",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/404a5ca4-59bb-4a86-896e-44b2ef57a24a"
    }
  }
}
